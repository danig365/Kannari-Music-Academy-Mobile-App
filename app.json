{
  "expo": {
    "name": "KannariMusicAcademy",
    "slug": "KannariMusicAcademy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kannarimusicacademy.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Kannari Music Academy needs microphone access to record audio messages for your teacher.",
        "NSPhotoLibraryUsageDescription": "Kannari Music Academy needs photo library access to update your profile picture."
      }
    },
    "android": {
      "package": "com.kannarimusicacademy.app",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.kannarimusicacademy",
          "enableGooglePay": true
        }
      ]
    ]
  }
}
